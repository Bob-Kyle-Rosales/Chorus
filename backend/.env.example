# .env.example
# Copy this file to .env and fill in your API keys.
# The .env file is gitignored — never commit it.
#
# Required for Phase 1 (real LLM + search calls):
GROQ_API_KEY=
TAVILY_API_KEY=
TOGETHER_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false

# Required before deploying anywhere reachable from the internet — the app
# boots and runs fine without these (local dev), but it logs a loud warning
# on every startup until they're set to real values. See config.py.
JWT_SECRET=
COOKIE_SECURE=false

# The deployed frontend origin(s), as a JSON array. Must match exactly, or
# the WebSocket that runs the pipeline will reject every connection.
ALLOWED_ORIGINS=["http://localhost:3000"]

# Optional — defaults to a local SQLite file if omitted. Set to a Postgres
# URL in production, e.g. postgresql+asyncpg://user:pass@host:5432/chorus
DATABASE_URL=
